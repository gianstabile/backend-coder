<section class="p-4 bg-secondary">
    <h2 class="text-primary">Products View</h2>
    {{#if productos}}

    <table class="table table-dark">
        <thead>
            <tr>
                <th>Name</th>
                <th>Price</th>
                <th>Thumb</th>
            </tr>
        </thead>
        <tbody>
            {{#each productos}}
            <tr class="text-center">
                <td class="align-middle">{{this.name}}</td>
                <td class="align-middle">{{this.price}}</td>
                <td class="align-middle">
                    <img src="{{this.picture}}" alt="{{this.name}}">
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>
    {{else}}
    <h2 class="bg-light p-4 text-danger">No products found</h2>
    {{/if}}
    <div class="mt-3">
        <a href="./productos">
            <button class="btn btn-warning">Add Product</button>
        </a>
    </div>
</section>